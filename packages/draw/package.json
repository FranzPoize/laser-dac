{
  "name": "@laser-dac/draw",
  "version": "0.6.1",
  "description": "Show laser drawing tools inspired by the canvas API",
  "license": "MIT",
  "author": "Kees Kluskens <kees@volst.nl>",
  "repository": "Volst/laser-dac",
  "keywords": [
    "etherdream",
    "laser",
    "ether-dream"
  ],
  "engines": {
    "node": ">=8.0"
  },
  "main": "dist/index.js",
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "watch": "tsc -p tsconfig.build.json --watch",
    "test": "jest",
    "prepublishOnly": "npm run -s build"
  },
  "dependencies": {
    "@laser-dac/ilda-reader": "^0.3.3",
    "@types/bezier-js": "^0.0.8",
    "@types/svg-parser": "^1.0.0",
    "bezier-js": "^6.1.4",
    "change-perspective": "^1.0.1",
    "svg-arc-to-cubic-bezier": "^3.2.0",
    "svg-parser": "^2.0.4",
    "svg-pathdata": "^7.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5"
  },
  "jest": {
    "roots": [
      "./src"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.(js|ts)$",
    "moduleFileExtensions": [
      "ts",
      "js",
      "json",
      "node"
    ]
  },
  "nx": {
    "targets": {
      "build": {
        "dependsOn": [
          "^build"
        ]
      }
    }
  }

}
